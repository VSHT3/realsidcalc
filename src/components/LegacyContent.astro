---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

const { source } = Astro.props;
const raw = readFileSync(resolve(process.cwd(), source), 'utf-8');
const bodyMatch = raw.match(/<body[^>]*>([\s\S]*)<\/body>/i);
let body = bodyMatch ? bodyMatch[1] : raw;

// Remove duplicated exported shell/nav/footer and export runtime noise.
body = body
  .replace(/<div style="display:contents"><div style="display:contents"><div class="w-html-embed"><nav class="nav-embed">[\s\S]*?<\/script>\s*<\/div><\/div><\/div>/i, '')
  .replace(/<div style="display:contents"><div style="display:contents"><div class="w-html-embed"><footer class="footer-embed">[\s\S]*?<\/style><\/div><\/div><\/div>/i, '')
  .replace(/<script>window.__reactRouterContext[\s\S]*$/i, '')
  .replace(/<iframe id="zotero-modal-prompt"[\s\S]*?<\/iframe>/gi, '')
  .replace(/<grammarly-desktop-integration[\s\S]*?<\/grammarly-desktop-integration>/gi, '')
  .replace(/(src|href)="([^"]*_files\/[^"]*)"/g, '$1="/legacy-assets/$2"')
  .replace(/(src|href)="([^"]*%20[^"]*_files\/[^"]*)"/g, '$1="/legacy-assets/$2"')
  .replace(/src="\/legacy-assets\/[^"]*embed\.html"/g, 'src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d652.0728525897156!2d16.605030069661147!3d49.17605667494077!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47129507feac52ad%3A0x5b858fd3dbffa63!2sPrazakova%201008%2F69%2C%20639%2000%20Brno-jih%2C%20Czechia!5e0!3m2!1sen!2ses!4v1772108890025!5m2!1sen!2ses"');
---
<Fragment set:html={body} />

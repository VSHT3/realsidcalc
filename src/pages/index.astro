      font-size: 15px;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: #2f251d;
    }
    .contact-aside-note p {
      margin: 0;
      font-size: 14px;
      line-height: 1.65;
      color: #5d5044;
    }

    .contact-form {
      grid-area: form;
      padding: var(--contact-form-pad);
      display: flex;
      flex-direction: column;
      gap: 14px;

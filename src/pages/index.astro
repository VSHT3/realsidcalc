            </span>
            <span class="method-text">
              <span class="method-label">Kalendář</span>
              <span class="method-value">Rezervovat konzultaci</span>
            </span>
          </a>
          <a class="contact-method" href="tel:+420771516683">
            <span class="method-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </span>
            <span class="method-text">
              <span class="method-label">Telefon</span>
              <span class="method-value">+420 771 516 683</span>
            </span>
          </a>
          <a class="contact-method" href="mailto:sebastian.kovac@smsfinance.cz">
            <span class="method-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </span>
            <span class="method-text">
              <span class="method-label">E-mail</span>
              <span class="method-value">sebastian.kovac@smsfinance.cz</span>
            </span>
          </a>
          <a class="contact-method" href="https://www.linkedin.com/in/sebasti%C3%A1n-kov%C3%A1%C4%8D-240530321/" target="_blank" rel="noopener noreferrer">
            <span class="method-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </span>
            <span class="method-text">
              <span class="method-label">LinkedIn</span>
              <span class="method-value">Sebastián Kováč</span>
            </span>
          </a>
        </div>
        <div class="contact-aside-note">
          <h4>Jak se spojíme</h4>
          <p>
            Odpovídám obvykle do 24 hodin. Konzultaci domluvíme osobně nebo online — podle toho, co vám vyhovuje.
          </p>
        </div>
      </aside>

      <form class="glass contact-form" action="/?index" method="post">
      <h3 class="form-heading">Napište mi</h3>
      <p class="lead">Vyplňte formulář a já se vám ozvu zpět co nejdříve.</p>
      <input type="hidden" name="ws--form-id" value="action" />
      <div class="field-grid">
        <label>Jméno<input name="name" type="text" required placeholder="Vaše jméno" /></label>
        <label>Telefon<input name="phone" type="tel" placeholder="+420 771 516 689" /></label>
        <label>Předmět
          <select name="Subject" required>
            <option value="" disabled selected>Vyberte..</option>
            <option>Finanční Diagnostika</option>
            <option>Investování do Nemovitostí</option>
            <option>Investice</option>
            <option>Penzijní spoření</option>
            <option>Úvěry</option>
            <option>Pojištění</option>
            <option>Jiný</option>
          </select>
        </label>
        <label>Způsob komunikace
          <select name="Communication Preference" required>
            <option value="" disabled selected>Vyberte..</option>
            <option>WhatsApp</option>
            <option>E-mail</option>
            <option>Telefon</option>
          </select>
        </label>
        <label class="field-full">E-mail<input name="email" type="email" required placeholder="vas@email.cz" /></label>
      </div>
      <label>Zpráva<textarea name="Zpráva" required placeholder="Vaše zpráva"></textarea></label>
      <button type="submit" class="submit-btn">Odeslat zprávu</button>
      </form>
    </div>
    </div>
  </section>

  <script>
    (() => {
      const counter = document.getElementById('clientCounter');
      if (counter) {
        const target = Number(counter.getAttribute('data-target') || 0);
        let start = 0;
        const duration = 1400;
        const t0 = performance.now();
        const run = (now) => {
          const p = Math.min((now - t0) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 4);
          counter.textContent = String(Math.floor(target * eased));
          if (p < 1) requestAnimationFrame(run);
        };
        requestAnimationFrame(run);
      }

      const tilt = document.getElementById('tiltCard');
      if (tilt) {
        tilt.addEventListener('mousemove', (e) => {
          const rect = tilt.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          tilt.style.transform = `perspective(900px) rotateX(${(-y * 5).toFixed(2)}deg) rotateY(${(x * 6).toFixed(2)}deg)`;
        });
        tilt.addEventListener('mouseleave', () => {
          tilt.style.transform = 'perspective(900px) rotateX(0deg) rotateY(0deg)';
        });
      }

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add('in');
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
    })();
  </script>

  <style>
    :global(body) {
      background: #f7f4ef;
      color: #201d19;
    }

    .hero,
    .services,
    .contact {
      position: relative;
      max-width: 1180px;
      margin: 0 auto;
      padding: clamp(32px, 5vw, 64px) clamp(18px, 3vw, 28px);
    }

    .wash {
      position: absolute;
      inset: 20px 12px auto;
      height: 420px;
      background: radial-gradient(circle at 12% 20%, rgba(255, 228, 214, 0.46), transparent 62%),
        radial-gradient(circle at 88% 15%, rgba(222, 237, 255, 0.5), transparent 58%),
        radial-gradient(circle at 50% 100%, rgba(236, 235, 255, 0.4), transparent 64%);
      filter: blur(32px);
      z-index: 0;
      pointer-events: none;
    }

    .hero-grid {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: clamp(18px, 2.7vw, 30px);
      align-items: stretch;
    }

    .glass {
      background: linear-gradient(120deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0.52));
      border: 1px solid rgba(255, 255, 255, 0.88);
      box-shadow: 0 24px 56px rgba(58, 48, 38, 0.12), inset 0 0 0 1px rgba(198, 190, 178, 0.2);
      backdrop-filter: blur(17px);
      -webkit-backdrop-filter: blur(17px);
      border-radius: 28px;
    }

    .hero-card {
      padding: clamp(26px, 3.7vw, 44px);
    }
    .hero-title {
      position: relative;
      z-index: 1;
      margin: 0 0 clamp(20px, 3vw, 32px);
      text-align: center;
      font-size: clamp(42px, 7.5vw, 76px);
      font-weight: 600;
      letter-spacing: 0.02em;
      line-height: 1.08;
      color: #1f1a15;
    }
    .eyebrow {
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #7f6e5b;
      margin: 0 0 14px;
    }
    h2 {
      margin: 0 0 12px;
      font-size: clamp(26px, 3.3vw, 38px);
      letter-spacing: 0.01em;
    }
    p {
      margin: 0 0 14px;
      line-height: 1.74;
      color: #372f28;
    }

    .stat-row {
      margin-top: 20px;
      display: inline-flex;
      flex-direction: column;
      gap: 6px;
    }
    .stat {
      display: inline-flex;
      align-items: baseline;
      gap: 2px;
      color: #5c4a3d;
      border-bottom: 2px solid #8c7460;
      padding-bottom: 6px;
    }
    .stat span:first-child {
      font-size: clamp(46px, 6vw, 72px);
      font-weight: 600;
      line-height: 1;
    }
    .plus {
      font-size: clamp(30px, 4vw, 48px);
      font-weight: 500;
    }

    .image-card {
      padding: clamp(14px, 1.6vw, 18px);
      display: grid;
      place-items: center;
    }
    .image-wrap {
      width: 100%;
      height: 100%;
      min-height: 500px;
      border-radius: 22px;
      overflow: hidden;
      transform-style: preserve-3d;
      transition: transform 220ms ease;
      box-shadow: 0 20px 45px rgba(47, 36, 29, 0.2);
    }
    .image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .service-card {
      padding: clamp(24px, 3vw, 36px);
    }

    .reviews {
      overflow: visible;
      padding-bottom: clamp(48px, 7vw, 88px);
    }
    .reviews-head {
      text-align: center;
      margin-bottom: 28px;
    }
    .reviews-head p {
      max-width: 740px;
      margin: 0 auto;
      color: #5d5044;
    }
    .reviews-marquee {
      position: relative;
      overflow-x: hidden;
      padding: 72px 0 88px;
      margin: 0 -12px;
    }
    @supports (overflow-x: clip) {
      .reviews-marquee {
        overflow-x: clip;
      }
    }
    .reviews-edge {
      position: absolute;
      top: 0;
      bottom: 0;
      width: min(120px, 12vw);
      z-index: 2;
      pointer-events: none;
    }
    .reviews-edge--left {
      left: 0;
      background: linear-gradient(to right, #f7f4ef 0%, rgba(247, 244, 239, 0) 100%);
    }
    .reviews-edge--right {
      right: 0;
      background: linear-gradient(to left, #f7f4ef 0%, rgba(247, 244, 239, 0) 100%);
    }
    .reviews-track {
      display: flex;
      gap: 28px;
      width: max-content;
      animation: review-scroll 120s linear infinite;
      padding: 8px 24px;
    }
    .reviews-marquee:hover .reviews-track {
      animation-play-state: paused;
    }
    .review-card {
      width: min(420px, 78vw);
      flex-shrink: 0;
      padding: 28px 26px;
      border-radius: 20px;
      box-shadow:
        0 18px 44px rgba(58, 48, 38, 0.11),
        0 0 0 1px rgba(198, 190, 178, 0.2);
    }
    .review-card p {
      margin: 0 0 14px;
      font-size: 17px;
      color: #3c322a;
      line-height: 1.6;
    }
    .review-card span {
      font-size: 14px;
      color: #7a6858;
      letter-spacing: 0.04em;
    }
    .stars {
      margin-bottom: 10px;
      color: #b58b52;
      letter-spacing: 0.12em;
      font-size: 15px;
    }
    .pill-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 14px;
    }
    .pill-grid span {
      padding: 9px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(229, 220, 209, 0.92);
      font-size: 13px;
      color: #4a3d31;
    }

    .contact-shell {
      padding: clamp(26px, 3.2vw, 42px);
    }
    .contact-header {
      text-align: center;
      max-width: 640px;
      margin: 0 auto 28px;
    }
    .contact-kicker {
      margin: 0 0 10px;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #8a6f52;
    }
    .contact-title {
      margin: 0 0 12px;
      font-size: clamp(28px, 4vw, 40px);
      font-weight: 600;
      letter-spacing: 0.02em;
      color: #1f1a15;
    }
    .contact-sub {
      margin: 0;
      font-size: 16px;
      line-height: 1.65;
      color: #5d5044;
    }

    .contact-columns {
      --contact-form-pad: clamp(22px, 2.8vw, 34px);
      display: grid;
      grid-template-columns: minmax(240px, 2fr) minmax(0, 3fr);
      grid-template-areas:
        'head-left form'
        'left      form';
      column-gap: clamp(16px, 2.5vw, 28px);
      row-gap: 0.5rem;
      grid-template-rows: auto 1fr;
      align-items: stretch;
    }
    .contact-info-heading {
      grid-area: head-left;
      margin: 0;
      padding-top: var(--contact-form-pad);
      font-size: 24px;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: #1f1a15;
      line-height: 1.2;
      align-self: start;
    }
    .contact-info {
      grid-area: left;
      display: flex;
      flex-direction: column;
      gap: 12px;
      min-height: 100%;
      min-width: 0;
    }
    .contact-methods {
      display: flex;
      flex-direction: column;
      gap: 2px;
      flex: 1;
    }
    .contact-method {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 6px 0;
      text-decoration: none;
      color: inherit;
      border-radius: 0;
      background: transparent;
      border: none;
      transition: color 0.2s ease;
    }
    .contact-method:hover .method-value {
      color: #4a3728;
    }
    .method-icon {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      display: inline-grid;
      place-items: center;
      flex-shrink: 0;
      color: #5c432f;
      background:
        linear-gradient(145deg, rgba(255, 236, 210, 0.95) 0%, rgba(232, 205, 168, 0.55) 48%, rgba(201, 168, 128, 0.45) 100%);
      border: 2px solid rgba(181, 139, 82, 0.55);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.65),
        inset 0 -1px 0 rgba(120, 90, 55, 0.12),
        0 6px 18px rgba(120, 90, 55, 0.14);
      transition:
        background 0.22s ease,
        border-color 0.22s ease,
        color 0.22s ease,
        box-shadow 0.22s ease,
        transform 0.22s ease;
    }
    .contact-method:hover .method-icon {
      color: #3d2a1a;
      background:
        linear-gradient(145deg, rgba(255, 244, 220, 1) 0%, rgba(238, 210, 168, 0.75) 45%, rgba(212, 176, 128, 0.65) 100%);

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/investice-page.css';
import investiceHtml from './_investice-fragment.html?raw';
---
<BaseLayout title="Investice" currentPath="/produkty/investice">
  <div class="investice-page" set:html={investiceHtml} />
</BaseLayout>

<script is:inline>
  (() => {
    const root = document.querySelector('.investice-page');
    if (!root) return;

    const progressBar = root.querySelector('#scrollProgress');
    const counter = root.querySelector('#aum-counter');
    const revealItems = root.querySelectorAll('.reveal');
    const barCols = root.querySelectorAll('.bar-col');
    const bars = root.querySelectorAll('.bar');

    function handleScroll() {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPerc = docHeight > 0 ? window.scrollY / docHeight : 0;
      if (progressBar) progressBar.style.width = `${scrollPerc * 100}%`;
    }

    function animateCounter(element) {
      if (!element) return;
      const target = +element.getAttribute('data-target');
      const duration = 3200;
      const start = performance.now();

      function frame(now) {
        const progress = Math.min((now - start) / duration, 1);
        const ease = 1 - Math.pow(1 - progress, 4);
        element.textContent = Math.floor(ease * target).toLocaleString('cs-CZ');
        if (progress < 1) requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
    }

    function initReveal() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.14, rootMargin: '0px 0px -40px 0px' }
      );

      revealItems.forEach((item) => observer.observe(item));
    }

    function initBars() {
      const graphCard = root.querySelector('.graph-card');
      if (!graphCard) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            bars.forEach((bar, index) => {
              const h = bar.getAttribute('data-height');
              setTimeout(() => {
                bar.style.height = h;
                bar.style.setProperty('--target-height', h);
                if (barCols[index]) barCols[index].classList.add('revealed');
              }, index * 120);
            });
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.3 }
      );

      observer.observe(graphCard);
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', handleScroll);
    handleScroll();
    initReveal();
    initBars();

    if (counter) {
      let ran = false;
      const observer = new IntersectionObserver(
        (entries) => {
          if (ran) return;
          if (entries[0].isIntersecting) {
            ran = true;
            animateCounter(counter);
            observer.disconnect();
          }
        },
        { threshold: 0.35 }
      );
      observer.observe(counter);
    }
  })();
</script>

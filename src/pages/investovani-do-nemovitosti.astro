---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/nemovitosti-page.css';
import nemovitostiHtml from './_nemovitosti-fragment.html?raw';
---
<BaseLayout title="Investování do Nemovitostí" currentPath="/investovani-do-nemovitosti">
  <div class="nemovitosti-page" set:html={nemovitostiHtml} />
</BaseLayout>

<script is:inline>
  (() => {
    const page = document.querySelector('.nemovitosti-page');
    if (!page) return;

    const assetsBase = 'https://assets.kovacsebastian.com/';
    const houseFiles = ['domcek1.svg', 'domcek2.svg', 'domcek3.svg', 'domcek4.svg', 'domcek5.webp'];

    function shuffleArray(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

    const shuffledHouses = shuffleArray([...houseFiles]);
    const hLeft = page.querySelector('#houseLeft');
    const hRight = page.querySelector('#houseRight');
    const progressBar = page.querySelector('#scrollProgress');
    const introPhoto = page.querySelector('#introPhoto');

    function createImg(src, alt) {
      const img = document.createElement('img');
      img.src = src;
      img.alt = alt;
      img.onerror = function () {
        this.src = assetsBase + 'domcek1.svg';
        this.onerror = null;
      };
      return img;
    }

    if (hLeft && !hLeft.hasChildNodes()) {
      hLeft.appendChild(createImg(assetsBase + shuffledHouses[0], 'House Left'));
    }

    if (hRight && !hRight.hasChildNodes()) {
      hRight.appendChild(createImg(assetsBase + shuffledHouses[1], 'House Right'));
    }

    function handleScroll() {
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollPerc = docHeight > 0 ? window.scrollY / docHeight : 0;
      const moveRange = Math.min(window.innerWidth * 0.24, 340);
      const floatOffset = Math.sin(scrollPerc * Math.PI * 3) * 18;
      const rotateLeft = scrollPerc * -8;
      const rotateRight = scrollPerc * 8;

      if (hLeft)
        hLeft.style.transform = `translateX(${-moveRange * scrollPerc}px) translateY(${floatOffset}px) rotate(${rotateLeft}deg)`;
      if (hRight)
        hRight.style.transform = `translateX(${moveRange * scrollPerc}px) translateY(${-floatOffset}px) rotate(${rotateRight}deg)`;

      const baseOpacity = window.innerWidth <= 768 ? 0.1 : 0.18;
      const fadeFactor = 1 - Math.min(scrollPerc * 0.35, 0.35);

      if (hLeft) hLeft.style.opacity = (baseOpacity * fadeFactor).toFixed(3);
      if (hRight) hRight.style.opacity = (baseOpacity * fadeFactor).toFixed(3);
      if (progressBar) progressBar.style.width = `${scrollPerc * 100}%`;
    }

    function handleMouseMove(e) {
      const x = (e.clientX / window.innerWidth) * 100;
      const y = (e.clientY / window.innerHeight) * 100;
      page.style.setProperty('--mouse-x', `${x}%`);
      page.style.setProperty('--mouse-y', `${y}%`);
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    window.addEventListener('resize', handleScroll);
    window.addEventListener('mousemove', handleMouseMove);
    handleScroll();

    const revealItems = page.querySelectorAll('.reveal-on-scroll');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.16 }
    );

    revealItems.forEach((item) => observer.observe(item));

    if (introPhoto && window.innerWidth > 1024) {
      introPhoto.addEventListener('mousemove', (e) => {
        const rect = introPhoto.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;

        const rotateY = (x / rect.width - 0.5) * 6;
        const rotateX = (y / rect.height - 0.5) * -5;

        introPhoto.style.transform = `translateY(-8px) perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.01)`;
      });

      introPhoto.addEventListener('mouseleave', () => {
        introPhoto.style.transform = '';
      });
    }
  })();
</script>
